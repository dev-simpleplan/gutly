
{% schema %}
  {
    "name": "Announcement Bar",
    "settings": [
      {
        "type": "text",
        "id": "text1",
        "label": "Text 1",
        "default": "FREE SHIPPING OVER $50."
      }, {
        "type": "text",
        "id": "text2",
        "label": "Text 2",
        "default": "FREE SHIPPING OVER $50."
      }, {
        "type": "page",
        "id": "link",
        "label": "CTA link"
      }
    ]
  }
{% endschema %}

<script>
  $('.announce-bar .owl-carousel').owlCarousel({
    loop: true,
    margin: 10,
    nav: false,
    dots: false,
    autoplay: true,
    autoplayTimeout: 7000,
    autoplayHoverPause: true,
    animateOut: 'fadeOut',
    responsive: {
      0: {
        items: 1
      },
      600: {
        items: 1
      },
      1000: {
        items: 1
      }
    }
  });
</script>