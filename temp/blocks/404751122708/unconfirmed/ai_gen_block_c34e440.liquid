{% doc %}
  @prompt
    Create a product feature section with 3 cards present in the same style and i want ot have a cTA for showing more, No I want products which. can be displayed here once added here later Like actual products, a CTA at the bottom to redirect the user to the collection page, Make the nackhroundcolout same as the footer
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-showcase__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-product-showcase__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-product-showcase__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-product-showcase__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-product-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-bottom: {{ block.settings.cta_spacing }}px;
  }

  .ai-product-showcase__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    display: block;
  }

  .ai-product-showcase__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-product-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    background-color: #f4f4f4;
    overflow: hidden;
  }

  .ai-product-showcase__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-showcase__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-showcase__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-showcase__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-product-showcase__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-product-showcase__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-product-showcase__product-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
    font-weight: 400;
  }

  .ai-product-showcase__product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_description_size }}px;
    color: {{ block.settings.product_description_color }};
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-product-showcase__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  .ai-product-showcase__cta-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.cta_alignment }};
  }

  .ai-product-showcase__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-product-showcase__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    transform: scale(1.05);
  }

  @media screen and (max-width: 989px) {
    .ai-product-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-product-showcase__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-product-showcase__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }
{% endstyle %}

<product-showcase-{{ ai_gen_id }} class="ai-product-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-showcase__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-product-showcase__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-product-showcase__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-product-showcase__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% liquid
      assign product_1 = block.settings.product_1
      assign product_2 = block.settings.product_2
      assign product_3 = block.settings.product_3
      assign has_products = false
      
      if product_1 != blank or product_2 != blank or product_3 != blank
        assign has_products = true
      endif
    %}

    {% if has_products %}
      <div class="ai-product-showcase__grid-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign product = block.settings[product_key]
          %}
          
          {% if product != blank %}
            <a href="{{ product.url }}" class="ai-product-showcase__card-{{ ai_gen_id }}">
              <div class="ai-product-showcase__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-showcase__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-product-showcase__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              
              <div class="ai-product-showcase__content-{{ ai_gen_id }}">
                <h3 class="ai-product-showcase__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                
                <div class="ai-product-showcase__product-price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-product-showcase__product-price-compare-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>
                
                {% if block.settings.show_description and product.description != blank %}
                  <div class="ai-product-showcase__product-description-{{ ai_gen_id }}">
                    {{ product.description | strip_html | truncate: 100 }}
                  </div>
                {% endif %}
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.show_cta and block.settings.cta_text != blank %}
        <div class="ai-product-showcase__cta-wrapper-{{ ai_gen_id }}">
          {% if block.settings.collection != blank %}
            <a href="{{ block.settings.collection.url }}" class="ai-product-showcase__cta-{{ ai_gen_id }}">
              {{ block.settings.cta_text }}
            </a>
          {% else %}
            <a href="{{ block.settings.cta_link }}" class="ai-product-showcase__cta-{{ ai_gen_id }}">
              {{ block.settings.cta_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% else %}
      <div class="ai-product-showcase__empty-state-{{ ai_gen_id }}">
        Next, add products to showcase
      </div>
    {% endif %}
  </div>
</product-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('product-showcase-{{ ai_gen_id }}', ProductShowcase{{ ai_gen_id }});
  })();
</script>

